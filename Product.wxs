<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="DrickSysApp" Language="1033" Version="1.0.0" Manufacturer="Drickoi" UpgradeCode="8F48BDA6-F2AF-4A16-B374-11C88A6C3B4A">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="DrickSysApp" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="DrickSysApp" />
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="DrickSysApp" Level="1">
      <ComponentGroupRef Id="DistFiles" />
      <ComponentRef Id="LauncherFileComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>

    <Icon Id="AppIcon" SourceFile="resources\myicon.png" />
  </Product>

  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="LauncherFileComponent" Guid="{A5C94DBD-30B5-4DB2-A4D5-6B14C1E8F0F5}">
        <File Id="LauncherCmd" KeyPath="yes" Source="RunDrickSysApp.cmd" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcutComponent" Guid="{7EE10489-3FCD-4F34-AFF8-BB8C43B7C0C0}">
        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="DrickSysApp"
          Target="[INSTALLFOLDER]RunDrickSysApp.cmd"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon"
          Advertise="no" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Drickoi\DrickSysApp" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
